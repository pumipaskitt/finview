# Environment variables สำหรับ controller.py
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรง หรือ set เป็น environment variable ตรงๆ

# URL ของ Node.js backend (Linux VPS)
API_URL=http://YOUR_SERVER_IP:3000

# ต้องตรงกับ SECRET_KEY ใน backend/.env
SECRET_KEY=change_this_to_a_secret_key

# Path ของ MT5 ที่ install จริง บน Windows VPS
MT5_BASE_DIR=C:\Program Files\MetaTrader 5

# Hash ของ MT5_BASE_DIR ใน APPDATA\MetaQuotes\Terminal\
# หาได้จากคำสั่ง PowerShell:
#   Get-ChildItem "$env:APPDATA\MetaQuotes\Terminal" -Directory | ForEach-Object {
#     $o = Join-Path $_.FullName "origin.txt"
#     if (Test-Path $o) { "$($_.Name) -> $(Get-Content $o)" }
#   }
MT5_BASE_HASH=YOUR_MT5_BASE_HASH_HERE

# Folder สำหรับเก็บ MT5 instances แต่ละ account
INSTANCES_DIR=C:\MT5_Instances

# Path ของ Python บน Windows VPS
PYTHON_EXE=C:\Program Files\Python311\python.exe

# Path ของ worker.py บน Windows VPS
WORKER_SCRIPT=C:\worker.py

# ดึง account list ทุกกี่วินาที
POLL_INTERVAL=10

# Sync ข้อมูลทุกกี่วินาที (ส่งให้ worker)
SYNC_INTERVAL=5
